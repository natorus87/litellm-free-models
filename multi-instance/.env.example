# =============================================================================
# Multi-Instance – Project-level .env (Docker Compose interpolation)
# =============================================================================
# Copy this file to .env in THIS directory:
#
#   cp .env.example .env
#
# Docker Compose resolves ${VAR} expressions in docker-compose.yaml ONLY from
# the shell environment or from this project-level .env – NEVER from the
# per-service env_file entries (master/.env, slave1/.env, slave2/.env).
# Shared infrastructure credentials (Redis, Postgres) therefore live here;
# the per-instance .env files carry only provider API keys.
# =============================================================================

# ─── Redis (shared cache for master + slaves) ────────────────────────────────
# Generate a strong password, e.g.: openssl rand -hex 16
REDIS_PASSWORD=
REDIS_PORT=6379

# ─── PostgreSQL (shared DB for key management & spend tracking) ──────────────
POSTGRES_USER=litellm
# Generate a strong password, e.g.: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=litellm
