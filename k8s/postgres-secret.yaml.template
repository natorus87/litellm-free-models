# =============================================================================
# Postgres – Secret TEMPLATE (do not apply as-is, do not commit real secrets)
# =============================================================================
# The real secret `litellm-postgres-secret` is created at deploy time by
# `make k8s-secret`, which reads POSTGRES_PASSWORD from your local .env:
#
#   make k8s-secret
#
# or manually:
#
#   kubectl create secret generic litellm-postgres-secret \
#     --namespace litellm-free-models \
#     --from-literal=postgres-password="<strong-password-here>"
#
# This file only documents the expected shape. It is intentionally NOT part
# of `make k8s-apply` so a committed default can never overwrite a real
# password.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: litellm-postgres-secret
  namespace: litellm-free-models
  labels:
    app.kubernetes.io/name: litellm-free-models
    app.kubernetes.io/component: database
type: Opaque
stringData:
  postgres-password: "<strong-password-here>"
