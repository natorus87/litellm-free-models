# =============================================================================
# MASTER LiteLLM Instance – Environment Variables
# =============================================================================
# The master has its OWN provider API keys PLUS keys to authenticate against
# each slave. When a model request arrives, the master can route directly
# (using its own keys) OR delegate to a slave (which uses the slave's keys).
#
# Each slave needs its OWN set of provider API keys (different accounts)
# to effectively multiply rate limits.
# =============================================================================

# ─── Master Authentication ───────────────────────────────────────────────────
# This key is used by CLIENTS to call the master API
LITELLM_MASTER_KEY=sk-master-change-me

# ─── Master's Own Provider API Keys ──────────────────────────────────────────
# The master can call providers directly with these keys
OPENROUTER_API_KEY=sk-or-v1-change-me
CEREBRAS_API_KEY=cerebras-change-me
GROQ_API_KEY=gsk-change-me
CLOUDFLARE_API_KEY=change-me
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1
GEMINI_API_KEY=AIza-change-me
NVIDIA_API_KEY=nvapi-change-me
MISTRAL_API_KEY=mistral-change-me
COHERE_API_KEY=cohere-change-me
GITHUB_TOKEN=github_pat_change_me
OPENCODE_ZEN_API_KEY=oczen-change-me
LLM7IO_API_KEY=unused
HF_TOKEN=hf_change_me

# ─── OVHcloud AI Endpoints ──────────────────────────────────────────
# Free anonymous tier: no API key required (2 RPM/IP/model).
# Optional API key for higher limits: https://www.ovhcloud.com/en/public-cloud/ai-endpoints/
# Leave empty for the anonymous free tier.
OVHCLOUD_API_KEY=

# ─── Slave Authentication (Keys to call each slave) ──────────────────────────
# These must match the LITELLM_MASTER_KEY of the respective slave.
# The master uses these to authenticate when routing requests to slaves.
SLAVE1_API_KEY=sk-slave1-change-me
SLAVE2_API_KEY=sk-slave2-change-me

# NOTE: Redis/Postgres credentials do NOT belong here. Docker Compose ignores
# per-service env_file entries when interpolating docker-compose.yaml, and the
# explicit environment: entries would override them anyway. Set them in
# multi-instance/.env instead (see multi-instance/.env.example).
