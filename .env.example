# =============================================================================
# LiteLLM Free-Models Proxy – Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env
#
# API Key registrations (all free):
#   OpenRouter:    https://openrouter.ai/keys
#   Cerebras:      https://cloud.cerebras.ai/
#   Groq:          https://console.groq.com/keys
#   Cloudflare:    https://dash.cloudflare.com/profile/api-tokens
#   Google AI:     https://aistudio.google.com/apikey
#   Mistral:       https://console.mistral.ai/
#   Cohere:        https://dashboard.cohere.com/api-keys
#   GitHub Models: https://github.com/settings/tokens (scope: models:read)
#   OpenCode Zen:  https://opencode.ai/zen
#   OVHcloud:      https://www.ovhcloud.com/en/public-cloud/ai-endpoints/
#   LLM7.io:       https://token.llm7.io (free token for higher rate limits)
#   HuggingFace:   https://huggingface.co/settings/tokens (free Inference API)
# =============================================================================

# ─── LiteLLM ────────────────────────────────────────────────────────────────
# Master key for proxy authentication. Clients send this as Bearer token.
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-your-random-master-key-here

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Database for LiteLLM key management, spend tracking, logging, and analytics.
# POSTGRES_PASSWORD is REQUIRED (docker-compose refuses to start without it).
# Generate a strong password, e.g.: openssl rand -hex 16
POSTGRES_USER=litellm
POSTGRES_PASSWORD=
POSTGRES_DB=litellm

# ─── OpenRouter ─────────────────────────────────────────────────────────────
# Free tier: 20 req/min, 50 req/day (shared across models)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ─── Cerebras ───────────────────────────────────────────────────────────────
# Free tier: 30 req/min, 14 400 req/day per model
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=cerebras-your-cerebras-key-here

# ─── Groq ───────────────────────────────────────────────────────────────────
# Free tier: varies by model (1 000 – 14 400 req/day)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── Cloudflare Workers AI ──────────────────────────────────────────────────
# Free tier: 10 000 neurons/day (shared across all models)
# API token:  https://dash.cloudflare.com/profile/api-tokens
# Account ID: https://developers.cloudflare.com/fundamentals/setup/find-account-and-zone-ids/
CLOUDFLARE_API_KEY=your-cloudflare-api-token-here
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4/accounts/your-account-id-here/ai/v1

# ─── NVIDIA NIM ─────────────────────────────────────────────────────────────
# Free tier: 40 req/min, phone verification required
# Get API key: https://build.nvidia.com/ (click "Get API Key" on any model)
# API is OpenAI-compatible at https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# ─── Google AI Studio (Gemini API) ──────────────────────────────────────────
# Free tier: 14 400 req/day for Gemma models
# NOTE: Derzeit nutzt KEIN Deployment diesen Key (gemma-3-Serie wurde von
# Google eingestellt). Der Key bleibt fuer zukuenftige Katalog-Syncs
# dokumentiert; leer lassen ist voellig OK.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Mistral La Plateforme ──────────────────────────────────────────────────
# Free tier (Experiment): 2 req/min, 500K tokens/min, 1B tokens/month
# All models included. Phone verification required.
# https://console.mistral.ai/
MISTRAL_API_KEY=mistral-your-mistral-api-key-here

# ─── Cohere ─────────────────────────────────────────────────────────────────
# Free tier (Trial key): 1 000 calls/month, 20 req/min chat, no credit card
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-trial-api-key-here

# ─── GitHub Models ──────────────────────────────────────────────────────────
# Free tier: rate-limited (15–150 req/day depending on model), no credit card
# Requires a GitHub PAT with "models:read" scope.
# https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_your-github-token-here

# ─── OpenCode Zen ───────────────────────────────────────────────────────────
# Free models: DeepSeek V4 Flash, Nemotron 3 Ultra, Big Pickle, North Mini Code
# Limited-time free tier, no credit card required to start.
# https://opencode.ai/zen
OPENCODE_ZEN_API_KEY=oczen-your-opencode-zen-key-here

# ─── OVHcloud AI Endpoints ─────────────────────────────────────────────────
# Free anonymous tier: no API key required (2 RPM/IP/model).
# Optional API key for higher limits: https://www.ovhcloud.com/en/public-cloud/ai-endpoints/
# Leer lassen für anonymen Free-Tier.
OVHCLOUD_API_KEY=

# ─── LLM7.io ─────────────────────────────────────────────────────────────────
# Free tier: 2 RPM (40 RPM with free token), 30+ models, no credit card required.
# Get free token for higher limits: https://token.llm7.io
# API is OpenAI-compatible at https://api.llm7.io/v1
# "unused" als Wert funktioniert für den Basis-Free-Tier ohne Token.
LLM7IO_API_KEY=unused

# ─── HuggingFace Inference API ───────────────────────────────────────────────
# Free Inference API: rate-limited, no credit card required, 150K+ models.
# Create a free HF token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your-huggingface-token-here

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Used by LiteLLM for response caching (identical prompts get served from
# cache) and for virtual-key authentication caching (across replicas).
#
# In Docker Compose the redis service is reachable as `redis` on port 6379.
# In Kubernetes the in-cluster service is `litellm-redis` (see k8s/redis/).
# Standalone setups can point to an external Redis by overriding REDIS_HOST.
# If REDIS_HOST is left empty/unset, render-config.py renders config.yaml
# WITHOUT the cache block (the proxy runs fine without Redis).
#
# REDIS_PASSWORD is REQUIRED when Redis is used (docker-compose refuses to
# start without it; `make k8s-secret` creates litellm-redis-secret from it).
# Generate a strong password, e.g.: openssl rand -hex 16
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
