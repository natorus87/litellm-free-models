# =============================================================================
# Multi-Instance LiteLLM – Kubernetes Secrets Template
# =============================================================================
#
# 3 separate Secrets, one per identity. Each has its OWN set of provider keys.
# Apply with:
#
#   kubectl create secret generic litellm-master-secrets \
#     --namespace litellm-free-models \
#     --from-literal=LITELLM_MASTER_KEY="sk-master-..." \
#     --from-literal=OPENROUTER_API_KEY="sk-or-v1-..." \
#     --from-literal=CEREBRAS_API_KEY="cerebras-..." \
#     --from-literal=GROQ_API_KEY="gsk_..." \
#     --from-literal=CLOUDFLARE_API_KEY="..." \
#     --from-literal=CLOUDFLARE_API_BASE="https://api.cloudflare.com/client/v4/accounts/.../ai/v1" \
#     --from-literal=GEMINI_API_KEY="AIza..." \
#     --from-literal=NVIDIA_API_KEY="nvapi-..." \
#     --from-literal=MISTRAL_API_KEY="..." \
#     --from-literal=COHERE_API_KEY="..." \
#     --from-literal=GITHUB_TOKEN="github_pat_..." \
#     --from-literal=OPENCODE_ZEN_API_KEY="oczen-..." \
#     --from-literal=SLAVE1_API_KEY="sk-slave1-..." \
#     --from-literal=SLAVE2_API_KEY="sk-slave2-..."
#
#   kubectl create secret generic litellm-slave1-secrets \
#     --namespace litellm-free-models \
#     --from-literal=LITELLM_MASTER_KEY="sk-slave1-..." \
#     --from-literal=OPENROUTER_API_KEY="...different..." \
#     ...
#
#   kubectl create secret generic litellm-slave2-secrets \
#     --namespace litellm-free-models \
#     --from-literal=LITELLM_MASTER_KEY="sk-slave2-..." \
#     ...
#
# DO NOT commit actual secrets!
#
# NOTE: REDIS_HOST/REDIS_PORT are static env vars in the Deployments
# (litellm-redis:6379); REDIS_PASSWORD comes from `litellm-redis-secret`,
# created via `make k8s-secret` at the repo root (see ../../k8s/redis/).
# =============================================================================

# ─── Master Secret ───────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: litellm-master-secrets
  namespace: litellm-free-models
  labels:
    app.kubernetes.io/name: litellm-free-models
    app.kubernetes.io/component: master
type: Opaque
stringData:
  LITELLM_MASTER_KEY: "sk-master-change-me"
  OPENROUTER_API_KEY: "sk-or-v1-change-me"
  CEREBRAS_API_KEY: "cerebras-change-me"
  GROQ_API_KEY: "gsk-change-me"
  CLOUDFLARE_API_KEY: "change-me"
  CLOUDFLARE_API_BASE: "https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1"
  GEMINI_API_KEY: "AIza-change-me"
  NVIDIA_API_KEY: "nvapi-change-me"
  MISTRAL_API_KEY: "mistral-change-me"
  COHERE_API_KEY: "cohere-change-me"
  GITHUB_TOKEN: "github_pat_change_me"
  OPENCODE_ZEN_API_KEY: "oczen-change-me"
  LLM7IO_API_KEY: "unused"
  HF_TOKEN: "hf_placeholder"
  # Slave auth keys – must match the LITELLM_MASTER_KEY of each slave
  SLAVE1_API_KEY: "sk-slave1-change-me"
  SLAVE2_API_KEY: "sk-slave2-change-me"

---

# ─── Slave 1 Secret ─────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: litellm-slave1-secrets
  namespace: litellm-free-models
  labels:
    app.kubernetes.io/name: litellm-free-models
    app.kubernetes.io/component: slave
type: Opaque
stringData:
  # Must match MASTER's SLAVE1_API_KEY
  LITELLM_MASTER_KEY: "sk-slave1-change-me"
  # DIFFERENT keys than master/slave2
  OPENROUTER_API_KEY: "sk-or-v1-change-me-slave1"
  CEREBRAS_API_KEY: "cerebras-change-me-slave1"
  GROQ_API_KEY: "gsk-change-me-slave1"
  CLOUDFLARE_API_KEY: "change-me-slave1"
  CLOUDFLARE_API_BASE: "https://api.cloudflare.com/client/v4/accounts/YOUR_SLAVE1_ACCOUNT_ID/ai/v1"
  GEMINI_API_KEY: "AIza-change-me-slave1"
  NVIDIA_API_KEY: "nvapi-change-me-slave1"
  MISTRAL_API_KEY: "mistral-change-me-slave1"
  COHERE_API_KEY: "cohere-change-me-slave1"
  GITHUB_TOKEN: "github_pat_change_me_slave1"
  OPENCODE_ZEN_API_KEY: "oczen-change-me-slave1"
  LLM7IO_API_KEY: "unused"
  HF_TOKEN: "hf_placeholder_slave1"

---

# ─── Slave 2 Secret ─────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: litellm-slave2-secrets
  namespace: litellm-free-models
  labels:
    app.kubernetes.io/name: litellm-free-models
    app.kubernetes.io/component: slave
type: Opaque
stringData:
  # Must match MASTER's SLAVE2_API_KEY
  LITELLM_MASTER_KEY: "sk-slave2-change-me"
  # DIFFERENT keys than master/slave1
  OPENROUTER_API_KEY: "sk-or-v1-change-me-slave2"
  CEREBRAS_API_KEY: "cerebras-change-me-slave2"
  GROQ_API_KEY: "gsk-change-me-slave2"
  CLOUDFLARE_API_KEY: "change-me-slave2"
  CLOUDFLARE_API_BASE: "https://api.cloudflare.com/client/v4/accounts/YOUR_SLAVE2_ACCOUNT_ID/ai/v1"
  GEMINI_API_KEY: "AIza-change-me-slave2"
  NVIDIA_API_KEY: "nvapi-change-me-slave2"
  MISTRAL_API_KEY: "mistral-change-me-slave2"
  COHERE_API_KEY: "cohere-change-me-slave2"
  GITHUB_TOKEN: "github_pat_change_me_slave2"
  OPENCODE_ZEN_API_KEY: "oczen-change-me-slave2"
  LLM7IO_API_KEY: "unused"
  HF_TOKEN: "hf_placeholder_slave2"
