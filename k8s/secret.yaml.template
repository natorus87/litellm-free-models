# =============================================================================
# LiteLLM Free-Models Proxy – Kubernetes Secret Template
# =============================================================================
# Apply this with real values (base64-encoded):
#
#   kubectl create secret generic litellm-secrets \
#     --namespace litellm-free-models \
#     --from-literal=LITELLM_MASTER_KEY="sk-..." \
#     --from-literal=OPENROUTER_API_KEY="sk-or-v1-..." \
#     --from-literal=CEREBRAS_API_KEY="cerebras-..." \
#     --from-literal=GROQ_API_KEY="gsk_..." \
#     --from-literal=CLOUDFLARE_API_KEY="..." \
#     --from-literal=CLOUDFLARE_API_BASE="https://api.cloudflare.com/client/v4/accounts/.../ai/v1" \
#     --from-literal=GEMINI_API_KEY="AIza..." \
#     --from-literal=MISTRAL_API_KEY="mistral-..." \
#     --from-literal=COHERE_API_KEY="..." \
#     --from-literal=GITHUB_TOKEN="github_pat_..." \
#     --from-literal=OPENCODE_ZEN_API_KEY="oczen-..." \
#     --from-literal=LLM7IO_API_KEY="unused" \
#     --from-literal=HF_TOKEN="hf_..."


# DO NOT commit the actual secret to git!
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: litellm-secrets
  namespace: litellm-free-models
  labels:
    app.kubernetes.io/name: litellm-free-models
    app.kubernetes.io/component: proxy
type: Opaque
stringData:
  LITELLM_MASTER_KEY: "sk-placeholder-replace-me"
  OPENROUTER_API_KEY: "sk-or-v1-placeholder"
  CEREBRAS_API_KEY: "cerebras-placeholder"
  GROQ_API_KEY: "gsk-placeholder"
  CLOUDFLARE_API_KEY: "placeholder"
  CLOUDFLARE_API_BASE: "https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1"
  NVIDIA_API_KEY: "nvapi-placeholder"
  GEMINI_API_KEY: "AIza-placeholder"
  MISTRAL_API_KEY: "mistral-placeholder"
  COHERE_API_KEY: "cohere-placeholder"
  GITHUB_TOKEN: "github_pat_placeholder"
  OPENCODE_ZEN_API_KEY: "oczen-placeholder"

  LLM7IO_API_KEY: "unused"
  HF_TOKEN: "hf_placeholder"

  # ⚠️ NVIDIA_API_KEY is also used for openai/ models with api_base=nvidia
  # ⚠️ GITHUB_TOKEN is also used for openai/ models with api_base=github

  # ─── Redis Cache ──────────────────────────────────────────────────────────
  # REDIS_HOST/REDIS_PORT are set as static env vars in the Deployment
  # (litellm-redis:6379). REDIS_PASSWORD is pulled from the separate
  # `litellm-redis-secret`, which `make k8s-secret` creates from .env.
  # See k8s/redis/ (deployment, service, secret template).
